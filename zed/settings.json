{
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["default", "plan"],
      },
      "type": "registry",
    },
  },
  "colorize_brackets": true,
  "vim_mode": true,
  "which_key": {
    "enabled": true,
    "delay_ms": 100,
  },
  "confirm_quit": false,
  "show_edit_predictions": true,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Material",
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "ui_font_family": "Iosevka Nerd Font",
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "cursor_blink": false,
  "project_panel": {
    "dock": "left",
    "button": true,
    "auto_fold_dirs": false,
  },
  "terminal": {
    "font_family": "Iosevka Nerd Font Mono",
    "blinking": "off",
    "font_size": 13,
  },
  "soft_wrap": "none",
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "scrollbar": {
    "show": "never",
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "normal",
      },
      "keyword": {
        "font_style": "normal",
      },
      "variable.parameter": {
        "font_style": "normal",
      },
      "punctuation.definition.keyword": {
        "font_style": "normal",
      },
      "markup.italic": {
        "font_style": "normal",
      },
    },
  },
}
