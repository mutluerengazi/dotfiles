{
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "medium",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "favorite_config_option_values": {
        "mode": ["plan", "build"],
      },
    },
  },
  "colorize_brackets": true,
  "vim": {
    "cursor_shape": {
      "normal": "block",
      "insert": "block",
      "replace": "underline",
      "visual": "block",
    },
  },
  "vim_mode": true,
  "which_key": {
    "enabled": true,
    "delay_ms": 100,
  },
  "confirm_quit": false,
  "show_edit_predictions": true,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 14,
  "buffer_font_size": 13,
  "ui_font_family": "FiraCode Nerd Font",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "cursor_blink": false,
  "project_panel": {
    "dock": "left",
    "button": true,
    "auto_fold_dirs": false,
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Mono",
    "blinking": "off",
    "font_size": 13,
  },
  "soft_wrap": "none",
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "scrollbar": {
    "show": "never",
  },
}
